{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && npm run build-only",
    "preview": "vite preview",
    "test:unit": "npm run type-check-tests && vitest",
    "test:cov": "npm run type-check-tests && vitest run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "type-check-tests": "vue-tsc --noEmit -p tsconfig.vitest.json",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@bcgov/design-tokens": "^4.0.0",
    "@mdi/js": "^7.4.47",
    "axios": "^1.18.1",
    "keycloak-js": "^26.2.0",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.5.0",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.10.0",
    "eslint-plugin-vuetify": "^2.7.2",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.4"
  },
  "depcheck": {
    "ignores": [
      "@vitest/coverage-v8"
    ]
  },
  "engines": {
    "node": "22",
    "npm": "10"
  }
}
