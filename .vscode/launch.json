{
  "compounds": [
    {
      "configurations": ["CSTAR Backend", "CSTAR Frontend"],
      "name": "CSTAR"
    },
    {
      "configurations": [
        "Integration Testing Backend",
        "Integration Testing JWKS"
      ],
      "name": "Integration Testing"
    }
  ],
  "configurations": [
    {
      "cwd": "${workspaceFolder}/backend",
      "name": "CSTAR Backend",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/frontend",
      "name": "CSTAR Frontend",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "ISSUER": "http://localhost:3001",
        "JWKS_URI": "http://localhost:3001/certs",
        "TMS_AUDIENCE": "cstar"
      },
      "name": "Integration Testing Backend",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/tests/integration/mock-jwks",
      "env": {
        "ISSUER": "http://localhost:3001",
        "TMS_AUDIENCE": "cstar"
      },
      "name": "Integration Testing JWKS",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["start"],
      "runtimeExecutable": "npm",
      "type": "node"
    }
  ],
  "version": "0.2.0"
}
