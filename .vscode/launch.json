{
  "compounds": [
    {
      "configurations": ["CSTAR Backend", "CSTAR Frontend"],
      "name": "CSTAR"
    }
  ],
  "configurations": [
    {
      "cwd": "${workspaceFolder}/backend",
      "name": "CSTAR Backend",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/frontend",
      "name": "CSTAR Frontend",
      "outputCapture": "std",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "ISSUER": "http://localhost:7002",
        "JWKS_URI": "http://localhost:7002/certs",
        "PORT": "7001",
        "POSTGRES_DATABASE": "tmsdb",
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PASSWORD": "testsecretpassword",
        "POSTGRES_PORT": "7003",
        "POSTGRES_USER": "tms",
        "TMS_AUDIENCE": "cstar"
      },
      "name": "Integration Tests Backend",
      "outputCapture": "std",
      "postDebugTask": "Integration Tests - Stop Dependencies",
      "preLaunchTask": "Integration Tests - Start Dependencies",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "type": "node"
    }
  ],
  "version": "0.2.0"
}
